# ═══════════════════════════════════════════════════════════════
# .env.example — 환경변수 템플릿. 이 파일을 복사해서 .env 로 쓴다:
#   copy .env.example .env   (PowerShell)   또는   cp .env.example .env
# .env 는 .gitignore 됨(비밀값 포함). 이 .example 만 커밋된다.
#
# 두 소비자가 이 파일을 읽는다:
#   1) docker-compose.yml  → POSTGRES_* / DB_PORT (홑밑줄) 를 읽어 DB 컨테이너를 띄움
#   2) settings.py         → DB__* / LLM__* (겹밑줄) 를 읽어 앱 설정을 만듦
# 그래서 DB 값은 "compose 용 이름"과 "앱 용 이름" 두 벌이 필요하다. 값은 똑같이 맞춘다.
# ═══════════════════════════════════════════════════════════════

# ── (1) docker-compose 가 읽는 변수 ─────────────────────────────
# pgvector 컨테이너가 최초 기동 시 이 값으로 DB·계정·비번을 만든다.
POSTGRES_DB=steam_rag
POSTGRES_USER=steam
POSTGRES_PASSWORD=steam
DB_PORT=5432                 # 호스트로 노출할 포트(override.yml). 충돌 시 5433 등으로 변경

# ── (2) settings.py 가 읽는 변수 ────────────────────────────────
# DB: 위 POSTGRES_* 와 "값을 동일하게" 유지할 것(진실의 원천은 사람이 맞춘다).
DB__HOST=localhost           # 앱→DB 접속 위치. 클라우드면 RDS 엔드포인트로
DB__PORT=5432                # DB_PORT 와 같은 값
DB__USER=steam               # POSTGRES_USER 와 같은 값
DB__PASSWORD=steam           # POSTGRES_PASSWORD 와 같은 값
DB__NAME=steam_rag           # POSTGRES_DB 와 같은 값

# LLM: 로컬 Ollama(네이티브) 기준 기본값. 클라우드 전환 시 provider·model 교체.
LLM__PROVIDER=ollama
LLM__BASE_URL=http://host.docker.internal:11434
LLM__MODEL=qwen3:14b
LLM__NUM_CTX=8192

# 기타 단일 설정
VECTOR_BACKEND=pgvector
EMBEDDING_MODEL=jhgan/ko-sroberta-multitask
STEAM_LANGUAGE=koreana
AGENT_MODE=simple